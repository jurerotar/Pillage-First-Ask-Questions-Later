{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "@pillage-first/web",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "author": "Jure Rotar <hello@jurerotar.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jurerotar/Pillage-First-Ask-Questions-Later",
    "directory": "apps/web"
  },
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "build:dev": "react-router build --mode development",
    "preview": "vite preview",
    "lint:check": "biome lint --no-errors-on-unmatched",
    "lint": "biome lint --fix --no-errors-on-unmatched",
    "lint:check/oxlint": "oxlint --type-aware",
    "lint/oxlint": "oxlint --type-aware --fix",
    "format:check": "biome ci --linter-enabled=false",
    "format": "biome check --write --no-errors-on-unmatched",
    "knip:ci": "knip --max-issues 29",
    "localize": "i18next-cli extract",
    "type-check": "react-router typegen && tsgo",
    "test": "vitest"
  },
  "dependencies": {
    "@grafana/faro-react": "2.3.1",
    "@grafana/faro-web-sdk": "2.3.1",
    "@hookform/resolvers": "5.2.2",
    "@mantine/hooks": "8.3.18",
    "@mdx-js/react": "3.1.1",
    "@mdx-js/rollup": "3.1.1",
    "@pillage-first/api": "*",
    "@pillage-first/db": "*",
    "@pillage-first/game-assets": "*",
    "@pillage-first/graphics": "0.1.2",
    "@pillage-first/mocks": "*",
    "@pillage-first/types": "*",
    "@pillage-first/utils": "*",
    "@react-router/node": "7.13.2",
    "@react-router/serve": "7.13.2",
    "@tanstack/react-query": "5.95.2",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "i18next": "25.10.9",
    "isbot": "5.1.36",
    "moderndash": "4.0.2",
    "peerjs": "1.5.5",
    "radix-ui": "1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.72.0",
    "react-i18next": "16.6.6",
    "react-icons": "5.6.0",
    "react-icons-sprite": "0.9.1",
    "react-router": "7.13.2",
    "react-tooltip": "5.30.0",
    "react-window": "1.8.11",
    "recharts": "3.8.0",
    "sonner": "2.0.7",
    "ts-seedrandom": "1.4.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@grafana/faro-rollup-plugin": "0.9.0",
    "@react-router/dev": "7.13.2",
    "@tailwindcss/vite": "4.2.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-window": "1.8.8",
    "@typescript/native-preview": "7.0.0-dev.20260324.1",
    "cheerio": "1.2.0",
    "happy-dom": "20.8.7",
    "i18next-cli": "1.50.5",
    "knip": "6.0.4",
    "rollup-plugin-visualizer": "7.0.1",
    "sass": "1.98.0",
    "tailwindcss": "4.2.2",
    "tailwindcss-safe-area": "1.3.0",
    "typescript": "6.0.2",
    "vite": "8.0.2",
    "vite-plugin-devtools-json": "1.0.0",
    "vite-plugin-pwa": "1.2.0",
    "vitest": "4.1.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "overrides": {
    "@react-router/dev": {
      "vite": "^8.0.0"
    }
  },
  "knip": {
    "$schema": "https://unpkg.com/knip@5/schema.json",
    "entry": [
      "scripts/*.ts",
      "app/**/*page.tsx!",
      "app/**/*layout.tsx!"
    ],
    "project": [
      "app/**/*.{ts,tsx}!"
    ]
  }
}
