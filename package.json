{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "pillage-first",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "author": "Jure Rotar <hello@jurerotar.com>",
  "repository": "github:jurerotar/Pillage-First-Ask-Questions-Later",
  "bugs": "https://github.com/jurerotar/Pillage-First-Ask-Questions-Later/issues",
  "packageManager": "npm@11.7.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prepare": "lefthook install",
    "inject-graphics": "node scripts/inject-graphics.ts",
    "remove-deprecated-directories": "node scripts/remove-deprecated-directories.ts",
    "extract-sql-schema": "node scripts/extract-sql-schema.ts",
    "extract-sql-usage": "node scripts/extract-sql-usage.ts",
    "extract-sql-seeder-usage": "node scripts/extract-sql-seeder-usage.ts",
    "generate-screenshots": "node scripts/generate-screenshots.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@playwright/test": "1.59.0",
    "@typescript/native-preview": "7.0.0-dev.20260330.1",
    "lefthook": "2.1.4",
    "oxlint": "1.58.0",
    "oxlint-tsgolint": "0.19.0",
    "playwright": "1.59.0",
    "sharp": "0.34.5",
    "turbo": "2.9.3",
    "typescript": "6.0.2"
  },
  "engines": {
    "node": ">=24.12.0"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "header-max-length": [
        0
      ],
      "body-max-line-length": [
        0
      ]
    }
  }
}
